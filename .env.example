# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@host:5432/nombre_bd"

# NextAuth — genera un secreto con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-seguro"

# URL pública de la app (sin barra final)
NEXTAUTH_URL="https://tu-dominio.com"

NODE_ENV="production"
