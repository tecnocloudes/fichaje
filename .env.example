# ─── Control plane ──────────────────────────────────────────────────────────
# Acceso pleno al schema master. Lo usan migraciones, seeds, worker (Fase 4),
# panel super-admin (Fase 7). NO usar desde la app del producto.
# ADR-001 §2.3 + §5.3.
MASTER_DATABASE_URL="postgresql://master_role:****@host:5432/fichaje?schema=master,public"

# Read-only sobre master.tenants, master.reserved_slugs, master.tenant_features,
# master.tenant_quota_usage. Usado por el middleware HTTP (Fase 3) y los
# helpers hasFeature/getLimit. ADR-002 §3.6 + ADR-004 §2.2.
TENANT_RUNTIME_DATABASE_URL="postgresql://tenant_runtime_role:****@host:5432/fichaje"

# SELECT/INSERT/UPDATE solo sobre master.tenant_quota_usage. Lo usa
# EXCLUSIVAMENTE consumeQuota (Fase 3-5). ADR-004 §2.2.
QUOTA_WRITER_DATABASE_URL="postgresql://quota_writer_role:****@host:5432/fichaje"

# Acceso a los schemas tenant_<slug> con app_role. La app del producto usa
# este cliente tras SET search_path por query (ADR-002 §2.2). Materializado
# en Fase 3. ADR-001 §2.3.
APP_DATABASE_URL="postgresql://app_role:****@host:5432/fichaje"

# Compat de Fase 2: si MASTER_DATABASE_URL no está, prismaMaster cae a
# DATABASE_URL. Fase 8 (cutover) elimina este alias. ADR-005 §2.3.a.
DATABASE_URL="postgresql://usuario:password@host:5432/fichaje"

# TTL del cache host→tenant del middleware HTTP (ms). Default 60000.
# ADR-002 §2.3 + §3.4.
TENANT_CACHE_TTL_MS="60000"

# ─── NextAuth ───────────────────────────────────────────────────────────────
# Genera un secreto con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-seguro"

# URL canónica del deployment (subdominio público de la landing/registro).
# trustHost: true en auth.config.ts permite que cada subdominio de tenant
# haga login. ADR-005 §2.4 + §3.2.
NEXTAUTH_URL="https://app.ficha.tecnocloud.es"

# ─── Stripe (Fase 4) ────────────────────────────────────────────────────────
# ADR-003 §5.4 + ADR-005 §2.3.b.
STRIPE_SECRET_KEY=""                 # sk_test_... en staging, sk_live_... en prod
STRIPE_PUBLISHABLE_KEY=""            # pk_test_... / pk_live_...
STRIPE_WEBHOOK_SECRET=""             # whsec_... distinto por endpoint y entorno

# Price IDs por plan y billing period (configurar en Stripe primero).
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_YEARLY=""

# Price IDs de los addons (Fase 4).
STRIPE_PRICE_ADDON_DOMINIO_PERSONALIZADO=""
STRIPE_PRICE_ADDON_API_ACCESS=""
STRIPE_PRICE_ADDON_INTEGRACIONES_NOMINA=""
STRIPE_PRICE_ADDON_FIRMA_ELECTRONICA=""
STRIPE_PRICE_ADDON_PEOPLE_ANALYTICS=""
STRIPE_PRICE_ADDON_STORAGE_EXTRA=""
STRIPE_PRICE_ADDON_EMAILS_EXTRA=""

# Trial: días y si requiere tarjeta upfront. ADR-003 §2.7 (enmienda).
STRIPE_TRIAL_DAYS="14"
STRIPE_TRIAL_REQUIRES_CARD="true"

# URLs de retorno tras checkout y portal de facturación.
STRIPE_PORTAL_RETURN_URL="https://<slug>.ficha.tecnocloud.es/configuracion"
STRIPE_CHECKOUT_SUCCESS_URL="https://app.ficha.tecnocloud.es/registro/exito?session_id={CHECKOUT_SESSION_ID}"
STRIPE_CHECKOUT_CANCEL_URL="https://app.ficha.tecnocloud.es/registro/cancelado"

# ─── Cloudflare (solo Traefik, NO la app) ───────────────────────────────────
# Token con scope mínimo Zone.DNS.Edit sobre ficha.tecnocloud.es + IP filter
# de la VPS. ADR-005 §2.1.b + §2.3.c. La app NO debe recibir esta variable.
# CLOUDFLARE_DNS_API_TOKEN=""

# ─── Build ──────────────────────────────────────────────────────────────────
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"
