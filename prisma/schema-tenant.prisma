// Schema Prisma del producto (modelos por tenant). Fase 3 — ADR-002 §2.2.
//
// Diseño intencional:
// - SIN multiSchema. Sin `schemas = [...]` en datasource y sin `@@schema(...)`
//   en los modelos. Esto fuerza a Prisma a NO cualificar el schema en el SQL
//   generado (los queries serán `SELECT * FROM "User"` sin prefijo de schema).
// - El cliente `prismaApp` aplicará `SET search_path TO "tenant_<slug>", public`
//   por query mediante `$extends({ query })`. Como las queries no llevan schema
//   cualificado, search_path las dirige al schema del tenant en runtime.
// - Las migraciones de este schema se aplican primero a un schema fijo
//   `tenant_template` (commits 11-12). Después se replican a cada
//   `tenant_<slug>` con `tenants:migrate <slug>` (commit 13) y `tenants:migrate:all`
//   (commit 14).
// - Las tablas del control plane (master.*) viven en `prisma/schema.prisma`
//   con su propio cliente (`prismaMaster`, `prismaRuntime`, `prismaQuotaWriter`).
//   Estos dos clientes son independientes — no comparten modelos ni
//   relaciones cross-schema.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-tenant"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum Rol {
  OWNER
  MANAGER
  EMPLEADO
}

enum TipoFichaje {
  ENTRADA
  PAUSA
  VUELTA_PAUSA
  SALIDA
}

enum MetodoFichaje {
  WEB
  MOVIL
  TABLET
  MANUAL
}

enum EstadoAusencia {
  PENDIENTE
  APROBADA
  RECHAZADA
  CANCELADA
}

enum EstadoTurno {
  BORRADOR
  PUBLICADO
}

enum EstadoPrenomina {
  BORRADOR
  CERRADA
  ENVIADA
}

enum TipoConceptoPrenomina {
  DIETA
  KILOMETRAJE
  COMISION
  PLUS
  BONUS
  DEDUCCION
  OTRO
}

// ─── Modelos del producto ──────────────────────────────────────────────────────

model Tienda {
  id           String    @id @default(cuid())
  nombre       String
  direccion    String
  ciudad       String
  codigoPostal String?
  telefono     String?
  email        String?
  latitud      Float?
  longitud     Float?
  radio        Int       @default(200)
  activa       Boolean   @default(true)
  color        String    @default("#6366f1")
  empleados    User[]
  fichajes     Fichaje[]
  turnos       Turno[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  password                 String?
  resetToken               String?                   @unique
  resetTokenExpiry         DateTime?
  nombre                   String
  apellidos                String
  dni                      String?                   @unique
  telefono                 String?
  foto                     String?
  fechaNacimiento          DateTime?
  rol                      Rol                       @default(EMPLEADO)
  tiendaId                 String?
  tienda                   Tienda?                   @relation(fields: [tiendaId], references: [id])
  activo                   Boolean                   @default(true)
  fichajes                 Fichaje[]
  turnos                   Turno[]
  ausencias                Ausencia[]                @relation("AusenciaEmpleado")
  ausenciasAprobadas       Ausencia[]                @relation("AusenciaAprobador")
  notificaciones           Notificacion[]
  tareas                   Tarea[]                   @relation("TareaAsignada")
  tareasCreadas            Tarea[]                   @relation("TareaCreada")
  comunicados              Comunicado[]
  articulos                Articulo[]
  documentos               Documento[]               @relation("DocumentoEmpleado")
  documentosSubidos        Documento[]               @relation("DocumentoSubido")
  firmas                   Firma[]                   @relation("FirmaUsuario")
  onboardings              ProcesoOnboarding[]
  bolsaHoras               BolsaHoras[]
  bolsaHorasAprobadas      BolsaHoras[]              @relation("BolsaHorasAprobador")
  denunciasInformante      Denuncia[]                @relation("DenunciaInformante")
  denunciasAsignadas       Denuncia[]                @relation("DenunciaAsignada")
  comentariosDenuncia      ComentarioDenuncia[]      @relation("ComentarioDenunciaAutor")
  solicitudesFirmaRecibidas SolicitudFirma[]         @relation("SolicitudFirmaDestinatario")
  solicitudesFirmaCreadas  SolicitudFirma[]          @relation("SolicitudFirmaSolicitante")
  // Organigrama: jerarquía de mando self-reference.
  managerId                String?
  manager                  User?                     @relation("ManagerSubordinados", fields: [managerId], references: [id])
  subordinados             User[]                    @relation("ManagerSubordinados")
  // Reclutamiento: usuarios que crearon ofertas / gestionan candidatos.
  ofertasCreadas           OfertaTrabajo[]           @relation("OfertaCreador")
  candidatosCreados        Candidato[]               @relation("CandidatoCreador")
  // Asistente IA: conversaciones del usuario.
  conversacionesIA         ConversacionIA[]          @relation("ConversacionIAUser")
  // Face ID: plantilla biométrica (opcional, máx 1 por usuario).
  faceTemplate             FaceTemplate?             @relation("FaceTemplateUser")
  preferenciasNotificacion PreferenciasNotificacion?
  pushSubscripciones       PushSubscripcion[]
  // OKRs: objetivos asignados / creados por el usuario.
  objetivosAsignados       Objetivo[]                @relation("ObjetivoAsignado")
  objetivosCreados         Objetivo[]                @relation("ObjetivoCreado")
  // Encuestas de clima: encuestas creadas + respuestas dadas.
  encuestasCreadas         Encuesta[]                @relation("EncuestaCreador")
  respuestasEncuesta       RespuestaEncuesta[]       @relation("RespuestaEncuestaUser")
  // Evaluaciones del desempeño: como evaluado, como evaluador.
  evaluacionesRecibidas    Evaluacion[]              @relation("EvaluacionEvaluado")
  evaluacionesARealizar    Evaluacion[]              @relation("EvaluacionEvaluador")
  // Control de gastos: tickets registrados.
  gastos                   Gasto[]
  gastosRevisados          Gasto[]                   @relation("GastoRevisor")
  // Reserva de espacios: mis reservas.
  reservasEspacios         ReservaEspacio[]
  // Envío de nóminas: archivos subidos a cada empleado.
  nominasArchivos          NominaArchivo[]           @relation("NominaArchivoEmpleado")
  nominasArchivosSubidos   NominaArchivo[]           @relation("NominaArchivoSubidoPor")
  // Formación LMS: cursos creados, asignaciones recibidas.
  cursosCreados            Curso[]                   @relation("CursoCreador")
  cursosAsignados          AsignacionCurso[]         @relation("AsignacionCursoEmpleado")
  // Custom requests: peticiones del empleado, gestionadas por OWNER/MANAGER.
  peticiones               Peticion[]                @relation("PeticionSolicitante")
  peticionesGestionadas    Peticion[]                @relation("PeticionGestor")
  // Chat: participaciones + mensajes enviados.
  conversaciones           ParticipanteConversacion[]
  mensajesEnviados         Mensaje[]                 @relation("MensajeAutor")
  // Multi-empresa: el usuario puede asociarse a una empresa concreta.
  empresaId                String?
  empresa                  Empresa?                  @relation(fields: [empresaId], references: [id])
  // Retribución flexible: declaraciones mensuales del empleado.
  declaracionesFlex        DeclaracionFlex[]
  // Prenómina: snapshots mensuales del empleado + cierres realizados.
  prenominas               Prenomina[]               @relation("PrenominaEmpleado")
  prenominasCerradas       Prenomina[]               @relation("PrenominaCerrador")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@index([tiendaId])
}

model Fichaje {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  tiendaId   String?
  tienda     Tienda?       @relation(fields: [tiendaId], references: [id])
  tipo       TipoFichaje
  timestamp  DateTime      @default(now())
  latitud    Float?
  longitud   Float?
  distancia  Float?
  metodo     MetodoFichaje @default(WEB)
  nota       String?
  editadoPor String?
  editadoEn  DateTime?
  ip         String?
  // Snapshot del rostro cifrado (AES-256-GCM, key IA_ENCRYPTION_KEY).
  // Solo se rellena cuando ConfiguracionEmpresa.faceIdGuardarFoto=true
  // y el fichaje viene del flujo Face ID.
  fotoSnapshotEnc Bytes?     @map("foto_snapshot_enc")
  createdAt  DateTime      @default(now())

  @@index([userId])
  @@index([tiendaId])
  @@index([timestamp])
}

model Turno {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  tiendaId   String
  tienda     Tienda      @relation(fields: [tiendaId], references: [id])
  fecha      DateTime
  horaInicio String
  horaFin    String
  nota       String?
  estado     EstadoTurno @default(BORRADOR)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
  @@index([tiendaId])
  @@index([fecha])
}

model TipoAusencia {
  id                 String     @id @default(cuid())
  nombre             String
  color              String     @default("#6366f1")
  icono              String     @default("calendar")
  pagada             Boolean    @default(true)
  requiereAprobacion Boolean    @default(true)
  diasMaximos        Int?
  ausencias          Ausencia[]
  activo             Boolean    @default(true)
  createdAt          DateTime   @default(now())
}

model Ausencia {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("AusenciaEmpleado", fields: [userId], references: [id])
  tipoAusenciaId  String
  tipoAusencia    TipoAusencia   @relation(fields: [tipoAusenciaId], references: [id])
  fechaInicio     DateTime
  fechaFin        DateTime
  dias            Int
  motivo          String?
  estado          EstadoAusencia @default(PENDIENTE)
  aprobadoPorId   String?
  aprobadoPor     User?          @relation("AusenciaAprobador", fields: [aprobadoPorId], references: [id])
  aprobadoEn      DateTime?
  comentarioAdmin String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([fechaInicio])
}

model Notificacion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  titulo    String
  mensaje   String
  tipo      String   @default("info")
  leida     Boolean  @default(false)
  enlace    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model ConfiguracionEmpresa {
  id                  String   @id @default(cuid())
  nombre              String   @default("Mi Empresa")
  logo                String?
  horasJornadaDiaria  Float    @default(8)
  horasSemanales      Float    @default(40)
  toleranciaFichaje   Int      @default(15)
  geofencingActivo    Boolean  @default(true)
  // Si true, el fichaje requiere geolocalización (lat/lon). Si false,
  // se acepta sin geo y el cliente puede saltarse la captura GPS.
  geoObligatoria      Boolean  @default(false) @map("geo_obligatoria")
  fichajeMovilActivo  Boolean  @default(true)
  fichajeTabletActivo Boolean  @default(true)
  // Si true, los empleados con Face ID registrado deben verificarlo
  // al fichar (no se permite fichar sin Face ID si lo tienen).
  faceIdObligatorio   Boolean  @default(false) @map("face_id_obligatorio")
  // Si true, al fichar con Face ID guardamos un snapshot cifrado del
  // frame de la cámara (en Fichaje.fotoSnapshotEnc) para auditoría.
  // Datos biométricos — RGPD art. 9. Off por defecto.
  faceIdGuardarFoto   Boolean  @default(false) @map("face_id_guardar_foto")
  // Días de retención del snapshot biométrico. El cron de purga
  // (`/api/cron/purge-biometrics`) borra fotos con `timestamp` mayor
  // a este número de días. RGPD art. 5.1.e (minimización).
  retencionFotosDias  Int      @default(90) @map("retencion_fotos_dias")
  notifAusencias      Boolean  @default(true)
  notifTurnos         Boolean  @default(true)
  notifTareas         Boolean  @default(true)
  notifFichajes       Boolean  @default(false)
  notifComunicados    Boolean  @default(true)
  emailActivo         Boolean  @default(false)
  emailHost           String?
  emailPort           Int?
  emailSecure         Boolean  @default(true)
  emailUser           String?
  emailPassword       String?
  emailFrom           String?
  pushActivo          Boolean  @default(false)
  pushVapidPublicKey  String?
  pushVapidPrivateKey String?
  favicon             String?
  colorPrimario       String   @default("#6366f1")
  colorSidebar        String   @default("#1e1b4b")
  appNombre           String   @default("TelecomFichaje")
  // Fase 6 §3.1: configuración general por tenant.
  zonaHoraria         String   @default("Europe/Madrid")
  diasLaborables      Int[]    @default([1, 2, 3, 4, 5])
  ausenciasDefaults   Json?
  // Reglas de cálculo de prenómina (feature `prenomina`, Enterprise-ready).
  nominaJornadaSemanal       Decimal @default(40.00) @db.Decimal(5, 2)
  nominaHoraExtraFactor      Decimal @default(1.75)  @db.Decimal(4, 2)
  nominaPlusNocturnidadActivo Boolean @default(false)
  nominaNocturnidadDesde     String  @default("22:00")
  nominaNocturnidadHasta     String  @default("06:00")
  nominaPlusNocturnidadFactor Decimal @default(1.25) @db.Decimal(4, 2)
  nominaPlusFestivoActivo    Boolean @default(false)
  nominaPlusFestivoFactor    Decimal @default(1.75)  @db.Decimal(4, 2)
  nominaSalarioBaseDefault   Decimal @default(0.00)  @db.Decimal(10, 2)
  nominaMoneda               String  @default("EUR")
  updatedAt           DateTime @updatedAt
}

model PreferenciasNotificacion {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inAppAusencias   Boolean  @default(true)
  inAppTurnos      Boolean  @default(true)
  inAppTareas      Boolean  @default(true)
  inAppFichajes    Boolean  @default(false)
  inAppComunicados Boolean  @default(true)
  emailAusencias   Boolean  @default(true)
  emailTurnos      Boolean  @default(true)
  emailTareas      Boolean  @default(false)
  emailFichajes    Boolean  @default(false)
  emailComunicados Boolean  @default(false)
  pushAusencias    Boolean  @default(true)
  pushTurnos       Boolean  @default(true)
  pushTareas       Boolean  @default(true)
  pushFichajes     Boolean  @default(false)
  pushComunicados  Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model PushSubscripcion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Tarea {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  prioridad   String    @default("MEDIA")
  completada  Boolean   @default(false)
  fechaLimite DateTime?
  asignadoAId String?
  asignadoA   User?     @relation("TareaAsignada", fields: [asignadoAId], references: [id])
  creadoPorId String
  creadoPor   User      @relation("TareaCreada", fields: [creadoPorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([asignadoAId])
  @@index([creadoPorId])
}

model Comunicado {
  id          String    @id @default(cuid())
  titulo      String
  contenido   String
  publicado   Boolean   @default(false)
  publicadoEn DateTime?
  autorId     String
  autor       User      @relation(fields: [autorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([autorId])
}

model Articulo {
  id        String   @id @default(cuid())
  titulo    String
  contenido String
  categoria String   @default("general")
  publicado Boolean  @default(false)
  vistas    Int      @default(0)
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([autorId])
}

model Documento {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  url         String?
  tipo        String   @default("otro")
  userId      String?
  user        User?    @relation("DocumentoEmpleado", fields: [userId], references: [id])
  subidoPorId String
  subidoPor   User     @relation("DocumentoSubido", fields: [subidoPorId], references: [id])
  createdAt   DateTime @default(now())
  firmas             Firma[]
  solicitudesFirma   SolicitudFirma[] @relation("SolicitudFirmaDocumento")

  @@index([userId])
  @@index([subidoPorId])
}

// Firma electrónica de documentos. Plan D.2 + Sprint 1 #2.
//
// Flujo: el OWNER/MANAGER crea una SolicitudFirma sobre un documento
// para uno o varios empleados. Cada empleado recibe la solicitud en
// su bandeja de firmas (`/empleado/firmas`) y al firmar se crea un
// registro `Firma` con el hash del documento, IP y user agent (sello
// temporal con valor probatorio básico — ENISA "firma simple avanzada").
//
// Integración con proveedor real (DocuSign/Signaturit) diferida a Fase 9.

enum EstadoSolicitudFirma {
  pendiente
  firmada
  rechazada
  expirada
}

model SolicitudFirma {
  id                String                @id @default(cuid())
  documentoId       String
  documento         Documento             @relation("SolicitudFirmaDocumento", fields: [documentoId], references: [id], onDelete: Cascade)
  destinatarioId    String
  destinatario      User                  @relation("SolicitudFirmaDestinatario", fields: [destinatarioId], references: [id])
  solicitadaPorId   String
  solicitadaPor     User                  @relation("SolicitudFirmaSolicitante", fields: [solicitadaPorId], references: [id])
  mensaje           String?
  estado            EstadoSolicitudFirma  @default(pendiente)
  expiraEn          DateTime?             @map("expira_en")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt      @map("updated_at")
  firma             Firma?                @relation("SolicitudFirma")

  @@index([destinatarioId])
  @@index([documentoId])
  @@index([estado])
}

model Firma {
  id              String          @id @default(cuid())
  documentoId     String
  documento       Documento       @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  userId          String
  user            User            @relation("FirmaUsuario", fields: [userId], references: [id])
  // Vínculo opcional con la solicitud. Una firma "espontánea" del propio
  // usuario sobre su documento NO requiere solicitud previa.
  solicitudId     String?         @unique
  solicitud       SolicitudFirma? @relation("SolicitudFirma", fields: [solicitudId], references: [id])
  documentHash    String          @map("document_hash")
  ip              String?
  userAgent       String?         @map("user_agent")
  firmadoEn       DateTime        @default(now()) @map("firmado_en")

  @@index([documentoId])
  @@index([userId])
}

model Festivo {
  id        String   @id @default(cuid())
  nombre    String
  fecha     DateTime
  ambito    String   @default("nacional")
  createdAt DateTime @default(now())
}

// Webhook outbound del tenant. Plan D.5.
model TenantWebhook {
  id          String   @id @default(cuid())
  url         String
  events      String[]
  secret      String
  active      Boolean  @default(true)
  lastFiredAt DateTime? @map("last_fired_at")
  failCount   Int      @default(0) @map("fail_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([active])
}

model ProcesoOnboarding {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  tipo        String            @default("ONBOARDING")
  estado      String            @default("PENDIENTE")
  fechaInicio DateTime
  fechaFin    DateTime?
  notas       String?
  tareas      TareaOnboarding[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
}

model TareaOnboarding {
  id          String            @id @default(cuid())
  procesoId   String
  proceso     ProcesoOnboarding @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  titulo      String
  descripcion String?
  completada  Boolean           @default(false)
  orden       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([procesoId])
}

model PlantillaTareaOnboarding {
  id          String   @id @default(cuid())
  tipo        String
  titulo      String
  descripcion String?
  orden       Int      @default(0)
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BolsaHoras {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  tipo          String
  horas         Float
  concepto      String
  fecha         DateTime
  aprobadoPorId String?
  aprobadoPor   User?    @relation("BolsaHorasAprobador", fields: [aprobadoPorId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ─── Canal de denuncias (Ley 2/2023) ───────────────────────────────────────────
//
// Buzón confidencial con plazos legales explícitos:
//   - Acuse de recibo en máx 7 días desde recepción.
//   - Resolución en máx 3 meses (prorrogable a 6 si se justifica).
//
// El informante puede ser anónimo. En ese caso se le devuelve un `accessToken`
// (256 bits) que sirve como única credencial para volver a consultar el
// estado y aportar nueva información sin revelar identidad.

enum CategoriaDenuncia {
  acoso_laboral
  acoso_sexual
  discriminacion
  fraude
  corrupcion
  incumplimiento_normativo
  proteccion_datos
  seguridad_salud
  otro
}

enum EstadoDenuncia {
  recibida
  acuse_recibido
  en_investigacion
  resuelta
  archivada
}

model Denuncia {
  id                   String            @id @default(cuid())
  // Anonimato y acceso
  esAnonima            Boolean           @default(false)
  // Token para que un informante anónimo consulte/responda sin login.
  // Hash del token real — el token plain solo se devuelve UNA VEZ al crear.
  accessTokenHash      String?           @unique
  // Datos de contacto del informante (null si anónima)
  informanteEmail      String?
  informanteNombre     String?
  informanteTelefono   String?
  // Si el denunciante es un usuario logueado (no anónimo), referencia.
  informanteUserId     String?
  informanteUser       User?             @relation("DenunciaInformante", fields: [informanteUserId], references: [id])
  // Datos de la denuncia
  asunto               String
  categoria            CategoriaDenuncia
  descripcion          String
  fechaIncidente       DateTime?
  // Estado y trazabilidad
  estado               EstadoDenuncia    @default(recibida)
  asignadoUserId       String?
  asignadoUser         User?             @relation("DenunciaAsignada", fields: [asignadoUserId], references: [id])
  // Plazos legales (Ley 2/2023)
  acuseReciboAt        DateTime?         @map("acuse_recibo_at")
  resolucionAt         DateTime?         @map("resolucion_at")
  resolucionResumen    String?           @map("resolucion_resumen")
  // Auditoría
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt      @map("updated_at")
  // Relaciones
  comentarios          ComentarioDenuncia[]

  @@index([estado])
  @@index([categoria])
  @@index([createdAt])
  @@index([asignadoUserId])
}

model ComentarioDenuncia {
  id          String   @id @default(cuid())
  denunciaId  String
  denuncia    Denuncia @relation(fields: [denunciaId], references: [id], onDelete: Cascade)
  // Quien escribe: usuario logueado o el informante anónimo (null + autorRole)
  autorUserId String?
  autorUser   User?    @relation("ComentarioDenunciaAutor", fields: [autorUserId], references: [id])
  // "informante" si lo escribe el denunciante anónimo via token,
  // "instructor" / "comite" / "owner" si lo escribe alguien del staff.
  autorRole   String
  contenido   String
  // Visibilidad: si es interno (notas del comité que el informante no ve)
  esInterno   Boolean  @default(false) @map("es_interno")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([denunciaId])
}

// ─── Reclutamiento (ATS) ───────────────────────────────────────────────────────
// Sprint 1 #3. Pipeline básico de selección: ofertas + candidatos.
// Cada candidato avanza por estados kanban (recibido → preselec → entrevista
// → oferta → contratado / rechazado). Los CV se almacenan como URL externa
// para evitar la complejidad de blob storage en este MVP.

enum EstadoOferta {
  borrador
  abierta
  pausada
  cerrada
}

enum EstadoCandidato {
  recibido
  preseleccionado
  entrevista
  oferta_enviada
  contratado
  rechazado
}

model OfertaTrabajo {
  id              String        @id @default(cuid())
  titulo          String
  descripcion     String
  departamento    String?
  ubicacion       String?
  modalidad       String?       // presencial / remoto / híbrido
  salarioMinCents Int?          @map("salario_min_cents")
  salarioMaxCents Int?          @map("salario_max_cents")
  estado          EstadoOferta  @default(borrador)
  fechaCierre     DateTime?     @map("fecha_cierre")
  creadorId       String
  creador         User          @relation("OfertaCreador", fields: [creadorId], references: [id])
  candidatos      Candidato[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt      @map("updated_at")

  @@index([estado])
  @@index([creadorId])
}

// ─── Asistente IA (Sprint 2 #1) ────────────────────────────────────────────────
//
// Modelo BYOK (Bring Your Own Key): cada tenant configura su propio
// proveedor de LLM (Anthropic / OpenAI / Google). La API key se guarda
// cifrada con AES-256-GCM (clave maestra en IA_ENCRYPTION_KEY env).
// El coste de tokens lo paga el tenant directamente al proveedor.

enum ProveedorIA {
  anthropic
  openai
  google
}

model IAConfiguracion {
  // Singleton por tenant. id fijo a "default" para garantizar 1 fila.
  id              String       @id @default("default")
  provider        ProveedorIA
  apiKeyEnc       Bytes        @map("api_key_enc")
  modelo          String       // ej. "claude-sonnet-4-6", "gpt-4o", "gemini-1.5-pro"
  endpointUrl     String?      @map("endpoint_url") // opcional para Azure/self-hosted
  systemPrompt    String?      @map("system_prompt") // override del system prompt
  activa          Boolean      @default(true)
  ultimaPruebaAt  DateTime?    @map("ultima_prueba_at")
  ultimaPruebaOk  Boolean?     @map("ultima_prueba_ok")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt      @map("updated_at")
}

model ConversacionIA {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation("ConversacionIAUser", fields: [userId], references: [id])
  titulo      String
  mensajes    MensajeIA[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt      @map("updated_at")

  @@index([userId])
  @@index([updatedAt])
}

model MensajeIA {
  id              String         @id @default(cuid())
  conversacionId  String
  conversacion    ConversacionIA @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  rol             String         // "user" | "assistant" | "system"
  contenido       String
  tokensInput     Int?           @map("tokens_input")
  tokensOutput    Int?           @map("tokens_output")
  modelo          String?
  errorMsg        String?        @map("error_msg")
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([conversacionId])
}

// ─── Face ID — fichaje con reconocimiento facial (Sprint 2 #2) ─────────────────
//
// El embedding facial (vector 128 floats normalizado) se almacena cifrado
// con AES-256-GCM (misma clave maestra que IA). Es irreversible: con el
// embedding solo se puede comparar (cosine similarity) contra otro
// embedding nuevo, no reconstruir la imagen original.

/// Chat interno. Feature: `chat`. MVP basado en polling (sin realtime).
///
/// `Conversacion` representa una conversación 1:1 (`tipo="directo"`)
/// o grupal (`tipo="grupo"`). Participantes en `ParticipanteConversacion`.
/// Mensajes ordenados por createdAt.
model Conversacion {
  id            String                      @id @default(cuid())
  nombre        String?
  tipo          String                      @default("directo") // directo | grupo
  creadoPorId   String?
  participantes ParticipanteConversacion[]
  mensajes      Mensaje[]
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
}

model ParticipanteConversacion {
  id              String       @id @default(cuid())
  conversacionId  String
  conversacion    Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ultimoLeidoAt   DateTime?
  createdAt       DateTime     @default(now())

  @@unique([conversacionId, userId])
  @@index([userId])
}

model Mensaje {
  id              String       @id @default(cuid())
  conversacionId  String
  conversacion    Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  autorId         String
  autor           User         @relation("MensajeAutor", fields: [autorId], references: [id])
  texto           String
  createdAt       DateTime     @default(now())

  @@index([conversacionId, createdAt])
}

/// Configuración WhatsApp Business (singleton). Feature: `whatsapp_bot`.
///
/// MVP: solo almacena las credenciales y registra mensajes a enviar en
/// `MensajeWhatsapp`. Sin envío real — un worker externo recogerá la
/// cola cuando se implemente la integración con WhatsApp Cloud API.
/// El token va cifrado con `IA_ENCRYPTION_KEY`.
model WhatsappConfig {
  id              String   @id @default("singleton")
  phoneNumberId   String?
  /// Token cifrado AES-GCM (mismo schema que IAConfiguracion.apiKeyEnc).
  tokenEnc        Bytes?
  numeroEmpresa   String?
  activo          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MensajeWhatsapp {
  id                    String   @id @default(cuid())
  destinatarioTelefono  String
  texto                 String
  estado                String   @default("pendiente") // pendiente | enviado | fallido
  motivoError           String?
  enviadoAt             DateTime?
  createdAt             DateTime @default(now())

  @@index([estado])
  @@index([createdAt])
}

/// Catálogo de integraciones del marketplace. Feature: `marketplace`.
///
/// Las integraciones son metadatos estáticos seedeados; cada tenant
/// activa las que quiera con su configuración propia. No hay ejecución
/// real — solo registro de que el tenant ha "conectado" la integración.
model Integracion {
  id            String                @id @default(cuid())
  slug          String                @unique
  nombre        String
  descripcion   String
  categoria     String                // "comunicacion" | "nominas" | "calendario" | etc.
  logoUrl       String?
  esquemaConfig Json?                 // JSON Schema de los campos config
  instalaciones IntegracionInstalada[]
  createdAt     DateTime              @default(now())
}

model IntegracionInstalada {
  id              String      @id @default(cuid())
  integracionId   String
  integracion     Integracion @relation(fields: [integracionId], references: [id], onDelete: Cascade)
  configuracion   Json
  activa          Boolean     @default(true)
  activadaPorId   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([integracionId])
}

/// Empresa dentro del tenant. Feature: `multi_empresa`. MVP: etiquetado.
///
/// Permite agrupar empleados/sedes bajo varios CIFs del mismo grupo
/// empresarial. Los datos siguen viviendo en el mismo schema tenant,
/// el `empresaId` es solo un campo de agrupación + filtrado en informes.
model Empresa {
  id           String   @id @default(cuid())
  nombre       String
  cif          String   @unique
  direccion    String?
  codigoPostal String?
  ciudad       String?
  pais         String?  @default("España")
  telefono     String?
  email        String?
  activa       Boolean  @default(true)
  usuarios     User[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Declaración mensual de retribución flexible. Feature: `retribucion_flex`.
///
/// El empleado declara importes en cada concepto (tickets restaurante,
/// guardería, transporte, seguro médico). El sistema calcula el ahorro
/// fiscal estimado con tablas internas. Sin emisión real de tickets —
/// la integración con proveedores (Cobee, Pluxee, Edenred) queda fuera.
model DeclaracionFlex {
  id          String   @id @default(cuid())
  empleadoId  String
  empleado    User     @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  periodo     String   // "2026-05"
  concepto    String   // tickets_restaurante | guarderia | transporte | seguro_medico
  importe     Decimal  @db.Decimal(10, 2)
  notas       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([empleadoId, periodo, concepto], name: "empleado_periodo_concepto_uniq")
  @@index([empleadoId, periodo])
}

/// Evaluación de desempeño 1:1 (evaluador → evaluado) en un ciclo.
/// Feature: `evaluaciones`. Pro+Enterprise.
model Evaluacion {
  id            String    @id @default(cuid())
  ciclo         String    // "2026-H1", "2026-Q1", etc.
  evaluadoAId   String
  evaluadoA     User      @relation("EvaluacionEvaluado", fields: [evaluadoAId], references: [id])
  evaluadorId   String
  evaluador     User      @relation("EvaluacionEvaluador", fields: [evaluadorId], references: [id])
  /// [{ idx, texto, tipo: "escala_1_5" | "texto" }]
  preguntas     Json
  /// [{ preguntaIdx, valor: number | string }] | null antes de completar
  respuestas    Json?
  comentarios   String?
  estado        String    @default("pendiente") // pendiente | completada
  createdAt     DateTime  @default(now())
  completadaAt  DateTime?

  @@index([evaluadoAId])
  @@index([evaluadorId])
  @@index([ciclo])
}

/// Gasto que el empleado registra para reembolso. Feature: `control_gastos`.
model Gasto {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  concepto     String
  importe      Decimal   @db.Decimal(10, 2)
  moneda       String    @default("EUR")
  categoria    String    @default("varios") // dietas | transporte | hotel | material | varios
  fecha        DateTime
  ticketUrl    String?   // URL/data del ticket subido (data URL pequeño OK)
  notas        String?
  estado       String    @default("pendiente") // pendiente | aprobado | rechazado
  revisorId    String?
  revisor      User?     @relation("GastoRevisor", fields: [revisorId], references: [id])
  revisadoAt   DateTime?
  comentarioRevision String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([estado])
  @@index([fecha])
}

/// Espacio reservable. Feature: `reserva_espacios`.
model EspacioReservable {
  id          String           @id @default(cuid())
  nombre      String
  descripcion String?
  capacidad   Int              @default(1)
  ubicacion   String?
  activo      Boolean          @default(true)
  reservas    ReservaEspacio[]
  createdAt   DateTime         @default(now())
}

model ReservaEspacio {
  id         String            @id @default(cuid())
  espacioId  String
  espacio    EspacioReservable @relation(fields: [espacioId], references: [id], onDelete: Cascade)
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  inicio     DateTime
  fin        DateTime
  motivo     String?
  createdAt  DateTime          @default(now())

  @@index([espacioId, inicio])
  @@index([userId])
}

/// Archivo de nómina enviado a un empleado. Feature: `envio_nominas`.
model NominaArchivo {
  id          String    @id @default(cuid())
  empleadoId  String
  empleado    User      @relation("NominaArchivoEmpleado", fields: [empleadoId], references: [id])
  /// "2026-04", "2026-05", etc. (mes de la nómina)
  periodo     String
  /// Data URL del PDF o URL externa. En MVP guardamos data URL.
  pdfUrl      String
  nombreArchivo String
  tamañoBytes Int       @default(0)
  subidoPorId String
  subidoPor   User      @relation("NominaArchivoSubidoPor", fields: [subidoPorId], references: [id])
  /// Marca de visualización por el empleado.
  vistoAt     DateTime?
  createdAt   DateTime  @default(now())

  @@unique([empleadoId, periodo], name: "empleado_periodo_uniq")
  @@index([empleadoId])
}

/// Curso de formación. Feature: `formacion`.
model Curso {
  id          String              @id @default(cuid())
  titulo      String
  descripcion String?
  /// URL externa al contenido (vídeo, PDF, web). Sin player propio en MVP.
  contenidoUrl String?
  duracionMin Int                 @default(60)
  creadoPorId String
  creadoPor   User                @relation("CursoCreador", fields: [creadoPorId], references: [id])
  asignaciones AsignacionCurso[]
  createdAt   DateTime            @default(now())
}

model AsignacionCurso {
  id           String   @id @default(cuid())
  cursoId      String
  curso        Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  empleadoId   String
  empleado     User     @relation("AsignacionCursoEmpleado", fields: [empleadoId], references: [id])
  fechaLimite  DateTime?
  completado   Boolean  @default(false)
  completadoAt DateTime?
  createdAt    DateTime @default(now())

  @@unique([cursoId, empleadoId], name: "curso_empleado_uniq")
  @@index([empleadoId])
}

/// Petición personalizada del empleado (carta, certificado, anticipo, etc.).
/// Feature: `custom_requests`.
model Peticion {
  id              String    @id @default(cuid())
  solicitanteId   String
  solicitante     User      @relation("PeticionSolicitante", fields: [solicitanteId], references: [id])
  tipo            String    // "certificado_empresa" | "anticipo" | "cambio_datos" | "otro"
  titulo          String
  descripcion     String
  estado          String    @default("pendiente") // pendiente | en_proceso | resuelta | rechazada
  respuesta       String?
  gestorId        String?
  gestor          User?     @relation("PeticionGestor", fields: [gestorId], references: [id])
  resueltaAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([solicitanteId])
  @@index([estado])
}

/// Encuesta de clima laboral. Feature: `encuestas_clima`. Pro+Enterprise.
///
/// Preguntas y respuestas se guardan como JSONB para evitar el costo
/// relacional de un esquema multitabla (Pregunta + Opcion + Respuesta
/// + Item) — para el caso de uso "encuesta pulse" con N preguntas
/// por encuesta, JSONB es mucho más simple sin perder consultabilidad.
///
/// Pregunta shape:
///   { idx: number, texto: string, tipo: "escala_1_5" | "texto" | "opcion", opciones?: string[] }
///
/// Si `anonima=true`, `RespuestaEncuesta.userId` se almacena como null;
/// el cliente no debe enviarlo y el backend lo fuerza a null. Sin esta
/// garantía, "encuesta anónima" sería una mentira.
model Encuesta {
  id          String              @id @default(cuid())
  titulo      String
  descripcion String?
  /// Array JSON de preguntas (orden según `idx`).
  preguntas   Json
  /// Si `true`, las respuestas no llevan `userId`. Inmutable tras crear.
  anonima     Boolean             @default(true)
  /// "borrador" | "abierta" | "cerrada".
  estado      String              @default("abierta")
  /// Fecha tope para responder. Tras esa fecha la encuesta queda cerrada.
  cierraAt    DateTime?
  creadoPorId String
  creadoPor   User                @relation("EncuestaCreador", fields: [creadoPorId], references: [id])
  respuestas  RespuestaEncuesta[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([estado])
}

model RespuestaEncuesta {
  id          String   @id @default(cuid())
  encuestaId  String
  encuesta    Encuesta @relation(fields: [encuestaId], references: [id], onDelete: Cascade)
  /// Null si la encuesta es anónima. Si la encuesta es nominal, FK al usuario.
  userId      String?
  user        User?    @relation("RespuestaEncuestaUser", fields: [userId], references: [id], onDelete: SetNull)
  /// Array JSON: [{ preguntaIdx: number, valor: number | string }].
  respuestas  Json
  createdAt   DateTime @default(now())

  @@unique([encuestaId, userId], name: "encuesta_user_uniq")
  @@index([encuestaId])
}

/// Objetivos / OKRs. Feature: `objetivos`. Pro+Enterprise.
///
/// Modelo simple: cada objetivo tiene un % de progreso (0-100) que se
/// actualiza manualmente. Key Results detallados (con valor actual /
/// objetivo / unidad) son una iteración futura.
///
/// Si `asignadoAId` es null, el objetivo es de empresa (afecta a toda
/// la organización). Si tiene valor, es individual del usuario.
model Objetivo {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String?
  asignadoAId String?
  asignadoA   User?    @relation("ObjetivoAsignado", fields: [asignadoAId], references: [id])
  /// Free text: "2026-Q1", "2026", "Mayo 2026", etc.
  periodo     String
  /// Free text con set conocido: "activo" | "completado" | "cancelado".
  estado      String   @default("activo")
  /// 0-100. Avance manual del objetivo.
  progreso    Int      @default(0)
  creadoPorId String
  creadoPor   User     @relation("ObjetivoCreado", fields: [creadoPorId], references: [id])
  fechaCierre DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([asignadoAId])
  @@index([estado])
  @@index([periodo])
}

model FaceTemplate {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation("FaceTemplateUser", fields: [userId], references: [id], onDelete: Cascade)
  embeddingEnc      Bytes    @map("embedding_enc")
  algoritmo         String   @default("face-api.js@0.22") // versión + librería
  // Consentimiento GDPR — registro inmutable del momento de la enrolación.
  consentimientoAt  DateTime @default(now()) @map("consentimiento_at")
  consentimientoIp  String?  @map("consentimiento_ip")
  consentimientoUa  String?  @map("consentimiento_ua")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt      @map("updated_at")

  verificaciones    FaceVerificacion[]
}

model FaceVerificacion {
  id          String        @id @default(cuid())
  templateId  String
  template    FaceTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  // Score de similitud cosine (0..1, más cerca de 1 = más parecido)
  score       Float
  // Resultado: match (>=umbral), no_match (<umbral), spoof (anti-spoof falló)
  resultado   String
  ip          String?
  userAgent   String?       @map("user_agent")
  // Si la verificación se asoció a un fichaje real (link débil — no FK
  // para no romper si el fichaje se borra/anonimiza).
  fichajeId   String?       @map("fichaje_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([templateId])
  @@index([createdAt])
}

model Candidato {
  id           String          @id @default(cuid())
  ofertaId     String
  oferta       OfertaTrabajo   @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  nombre       String
  apellidos    String
  email        String
  telefono     String?
  cvUrl        String?         @map("cv_url")
  linkedinUrl  String?         @map("linkedin_url")
  notas        String?
  estado       EstadoCandidato @default(recibido)
  // Quien lo creó (admin que añadió al candidato manualmente,
  // o null si llegó vía portal público de la oferta).
  creadorId    String?
  creador      User?           @relation("CandidatoCreador", fields: [creadorId], references: [id])
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt      @map("updated_at")

  @@index([ofertaId])
  @@index([estado])
  @@index([email])
}

/// Prenómina persistida: snapshot mensual por empleado con cifras
/// calculadas (horas/extras/ausencias/importes), conceptos manuales
/// editables y workflow de cierre (BORRADOR → CERRADA → ENVIADA).
/// Feature: `prenomina` (Pro+Enterprise).
model Prenomina {
  id                   String                @id @default(cuid())
  periodo              String                // "YYYY-MM"
  empleadoId           String
  empleado             User                  @relation("PrenominaEmpleado", fields: [empleadoId], references: [id], onDelete: Cascade)
  estado               EstadoPrenomina       @default(BORRADOR)
  horasTrabajadas      Decimal               @default(0) @db.Decimal(7, 2)
  horasOrdinarias      Decimal               @default(0) @db.Decimal(7, 2)
  horasExtras          Decimal               @default(0) @db.Decimal(7, 2)
  horasNocturnas       Decimal               @default(0) @db.Decimal(7, 2)
  horasFestivas        Decimal               @default(0) @db.Decimal(7, 2)
  diasTrabajados       Int                   @default(0)
  diasAusenciaPagada   Int                   @default(0)
  diasAusenciaNoPagada Int                   @default(0)
  salarioBase          Decimal               @default(0) @db.Decimal(10, 2)
  importeHorasExtras   Decimal               @default(0) @db.Decimal(10, 2)
  importeNocturnidad   Decimal               @default(0) @db.Decimal(10, 2)
  importeFestivos      Decimal               @default(0) @db.Decimal(10, 2)
  importeConceptos     Decimal               @default(0) @db.Decimal(10, 2)
  totalBruto           Decimal               @default(0) @db.Decimal(10, 2)
  moneda               String                @default("EUR")
  comentario           String?
  calculadaAt          DateTime?
  cerradaAt            DateTime?
  cerradaPorId         String?
  cerradaPor           User?                 @relation("PrenominaCerrador", fields: [cerradaPorId], references: [id], onDelete: SetNull)
  enviadaAt            DateTime?
  conceptos            PrenominaConcepto[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([periodo, empleadoId])
  @@index([periodo])
  @@index([empleadoId])
  @@index([estado])
}

/// Concepto manual añadido a una Prenomina (dieta, kilometraje,
/// comisión, plus, bonus, deducción o "otro"). Se suma a
/// `Prenomina.importeConceptos` al guardar.
model PrenominaConcepto {
  id           String                 @id @default(cuid())
  prenominaId  String
  prenomina    Prenomina              @relation(fields: [prenominaId], references: [id], onDelete: Cascade)
  tipo         TipoConceptoPrenomina
  descripcion  String
  cantidad     Decimal?               @db.Decimal(8, 2)
  importe      Decimal                @db.Decimal(10, 2)
  notas        String?
  createdAt    DateTime               @default(now())

  @@index([prenominaId])
}
