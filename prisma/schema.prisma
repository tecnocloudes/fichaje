generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  SUPERADMIN
  MANAGER
  EMPLEADO
}

enum TipoFichaje {
  ENTRADA
  PAUSA
  VUELTA_PAUSA
  SALIDA
}

enum MetodoFichaje {
  WEB
  MOVIL
  TABLET
  MANUAL
}

enum EstadoAusencia {
  PENDIENTE
  APROBADA
  RECHAZADA
  CANCELADA
}

enum EstadoTurno {
  BORRADOR
  PUBLICADO
}

model Tienda {
  id           String    @id @default(cuid())
  nombre       String
  direccion    String
  ciudad       String
  codigoPostal String?
  telefono     String?
  email        String?
  latitud      Float?
  longitud     Float?
  radio        Int       @default(200)
  activa       Boolean   @default(true)
  color        String    @default("#6366f1")
  empleados    User[]
  fichajes     Fichaje[]
  turnos       Turno[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  password                 String?
  resetToken               String?                   @unique
  resetTokenExpiry         DateTime?
  nombre                   String
  apellidos                String
  dni                      String?                   @unique
  telefono                 String?
  foto                     String?
  fechaNacimiento          DateTime?
  rol                      Rol                       @default(EMPLEADO)
  tiendaId                 String?
  tienda                   Tienda?                   @relation(fields: [tiendaId], references: [id])
  activo                   Boolean                   @default(true)
  fichajes                 Fichaje[]
  turnos                   Turno[]
  ausencias                Ausencia[]                @relation("AusenciaEmpleado")
  ausenciasAprobadas       Ausencia[]                @relation("AusenciaAprobador")
  notificaciones           Notificacion[]
  tareas                   Tarea[]                   @relation("TareaAsignada")
  tareasCreadas            Tarea[]                   @relation("TareaCreada")
  comunicados              Comunicado[]
  articulos                Articulo[]
  documentos               Documento[]               @relation("DocumentoEmpleado")
  documentosSubidos        Documento[]               @relation("DocumentoSubido")
  onboardings              ProcesoOnboarding[]
  bolsaHoras               BolsaHoras[]
  bolsaHorasAprobadas      BolsaHoras[]              @relation("BolsaHorasAprobador")
  preferenciasNotificacion PreferenciasNotificacion?
  pushSubscripciones       PushSubscripcion[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@index([tiendaId])
}

model Fichaje {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  tiendaId   String?
  tienda     Tienda?       @relation(fields: [tiendaId], references: [id])
  tipo       TipoFichaje
  timestamp  DateTime      @default(now())
  latitud    Float?
  longitud   Float?
  distancia  Float?
  metodo     MetodoFichaje @default(WEB)
  nota       String?
  editadoPor String?
  editadoEn  DateTime?
  ip         String?
  createdAt  DateTime      @default(now())

  @@index([userId])
  @@index([tiendaId])
  @@index([timestamp])
}

model Turno {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  tiendaId   String
  tienda     Tienda      @relation(fields: [tiendaId], references: [id])
  fecha      DateTime
  horaInicio String
  horaFin    String
  nota       String?
  estado     EstadoTurno @default(BORRADOR)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
  @@index([tiendaId])
  @@index([fecha])
}

model TipoAusencia {
  id                 String     @id @default(cuid())
  nombre             String
  color              String     @default("#6366f1")
  icono              String     @default("calendar")
  pagada             Boolean    @default(true)
  requiereAprobacion Boolean    @default(true)
  diasMaximos        Int?
  ausencias          Ausencia[]
  activo             Boolean    @default(true)
  createdAt          DateTime   @default(now())
}

model Ausencia {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("AusenciaEmpleado", fields: [userId], references: [id])
  tipoAusenciaId  String
  tipoAusencia    TipoAusencia   @relation(fields: [tipoAusenciaId], references: [id])
  fechaInicio     DateTime
  fechaFin        DateTime
  dias            Int
  motivo          String?
  estado          EstadoAusencia @default(PENDIENTE)
  aprobadoPorId   String?
  aprobadoPor     User?          @relation("AusenciaAprobador", fields: [aprobadoPorId], references: [id])
  aprobadoEn      DateTime?
  comentarioAdmin String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([fechaInicio])
}

model Notificacion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  titulo    String
  mensaje   String
  tipo      String   @default("info")
  leida     Boolean  @default(false)
  enlace    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model ConfiguracionEmpresa {
  id                     String   @id @default(cuid())
  nombre                 String   @default("Mi Empresa")
  logo                   String?
  horasJornadaDiaria     Float    @default(8)
  horasSemanales         Float    @default(40)
  toleranciaFichaje      Int      @default(15)
  geofencingActivo       Boolean  @default(true)
  fichajeMovilActivo     Boolean  @default(true)
  fichajeTabletActivo    Boolean  @default(true)
  // Notificaciones - eventos globales
  notifAusencias         Boolean  @default(true)
  notifTurnos            Boolean  @default(true)
  notifTareas            Boolean  @default(true)
  notifFichajes          Boolean  @default(false)
  notifComunicados       Boolean  @default(true)
  // Email
  emailActivo            Boolean  @default(false)
  emailHost              String?
  emailPort              Int?
  emailSecure            Boolean  @default(true)
  emailUser              String?
  emailPassword          String?
  emailFrom              String?
  // Push
  pushActivo             Boolean  @default(false)
  pushVapidPublicKey     String?
  pushVapidPrivateKey    String?
  // Branding
  favicon                String?  // base64 data URL
  colorPrimario          String   @default("#6366f1")
  colorSidebar           String   @default("#1e1b4b")
  appNombre              String   @default("TelecomFichaje")
  updatedAt              DateTime @updatedAt
}

model PreferenciasNotificacion {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // In-app
  inAppAusencias   Boolean  @default(true)
  inAppTurnos      Boolean  @default(true)
  inAppTareas      Boolean  @default(true)
  inAppFichajes    Boolean  @default(false)
  inAppComunicados Boolean  @default(true)
  // Email
  emailAusencias   Boolean  @default(true)
  emailTurnos      Boolean  @default(true)
  emailTareas      Boolean  @default(false)
  emailFichajes    Boolean  @default(false)
  emailComunicados Boolean  @default(false)
  // Push
  pushAusencias    Boolean  @default(true)
  pushTurnos       Boolean  @default(true)
  pushTareas       Boolean  @default(true)
  pushFichajes     Boolean  @default(false)
  pushComunicados  Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model PushSubscripcion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Tarea {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  prioridad   String    @default("MEDIA")
  completada  Boolean   @default(false)
  fechaLimite DateTime?
  asignadoAId String?
  asignadoA   User?     @relation("TareaAsignada", fields: [asignadoAId], references: [id])
  creadoPorId String
  creadoPor   User      @relation("TareaCreada", fields: [creadoPorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([asignadoAId])
  @@index([creadoPorId])
}

model Comunicado {
  id          String    @id @default(cuid())
  titulo      String
  contenido   String
  publicado   Boolean   @default(false)
  publicadoEn DateTime?
  autorId     String
  autor       User      @relation(fields: [autorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([autorId])
}

model Articulo {
  id        String   @id @default(cuid())
  titulo    String
  contenido String
  categoria String   @default("general")
  publicado Boolean  @default(false)
  vistas    Int      @default(0)
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([autorId])
}

model Documento {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  url         String?
  tipo        String   @default("otro")
  userId      String?
  user        User?    @relation("DocumentoEmpleado", fields: [userId], references: [id])
  subidoPorId String
  subidoPor   User     @relation("DocumentoSubido", fields: [subidoPorId], references: [id])
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([subidoPorId])
}

model Festivo {
  id        String   @id @default(cuid())
  nombre    String
  fecha     DateTime
  ambito    String   @default("nacional")
  createdAt DateTime @default(now())
}

model ProcesoOnboarding {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id])
  tipo        String              @default("ONBOARDING")
  estado      String              @default("PENDIENTE")
  fechaInicio DateTime
  fechaFin    DateTime?
  notas       String?
  tareas      TareaOnboarding[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId])
}

model TareaOnboarding {
  id          String            @id @default(cuid())
  procesoId   String
  proceso     ProcesoOnboarding @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  titulo      String
  descripcion String?
  completada  Boolean           @default(false)
  orden       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([procesoId])
}

model PlantillaTareaOnboarding {
  id          String   @id @default(cuid())
  tipo        String   // "ONBOARDING" | "OFFBOARDING"
  titulo      String
  descripcion String?
  orden       Int      @default(0)
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BolsaHoras {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  tipo          String   // "ACUMULACION" | "CONSUMO"
  horas         Float
  concepto      String
  fecha         DateTime
  aprobadoPorId String?
  aprobadoPor   User?    @relation("BolsaHorasAprobador", fields: [aprobadoPorId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}
