generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["master", "public"]
}

// ─── Control plane (schema master) ─────────────────────────────────────────────
//
// Enums introducidos en Fase 2 (commit 1). Los modelos del control plane se
// añaden en commits siguientes.

enum TenantStatus {
  pending
  provisioning
  active
  suspended
  deleted

  @@schema("master")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  unpaid
  canceled
  paused
  incomplete
  incomplete_expired

  @@schema("master")
}

enum FeatureSource {
  plan
  addon
  manual_override

  @@schema("master")
}

enum FeatureType {
  boolean
  limit
  quota

  @@schema("master")
}

enum PlatformRol {
  SUPER_ADMIN
  SUPPORT

  @@schema("master")
}

// Tenant: núcleo del control plane.
//
// El CHECK del slug `^[a-z][a-z0-9_]{2,30}$` se aplica con un CHECK constraint
// SQL añadido en la migración (Prisma no soporta CHECK declarativo todavía).
// El trigger `tenants_slug_not_reserved` rechaza inserts cuyo slug colisione
// con master.reserved_slugs (también en SQL).
//
// La columna stripe_customer_id es nullable hasta que el primer checkout
// asigna el Customer Stripe. Para el cliente actual del cutover (Fase 8) se
// usa el sentinel "cus_manual_<id>" que no colisiona con prefijos reales.
model Tenant {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  email            String
  status           TenantStatus    @default(pending)
  stripeCustomerId String?         @unique @map("stripe_customer_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  tenantFeatures   TenantFeature[]
  subscriptions    Subscription[]

  @@index([status])
  @@map("tenants")
  @@schema("master")
}

// Slugs reservados de la plataforma. Trigger en master.tenants rechaza
// inserts cuyo slug exista aquí. Lista inicial sembrada en seeds.
model ReservedSlug {
  slug      String   @id
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reserved_slugs")
  @@schema("master")
}

// Plan: starter / pro / enterprise. Sin precios — los precios viven en
// Stripe (vars STRIPE_PRICE_* de ADR-005 §2.3.b). Aquí solo metadatos
// para la UI de selección de plan en app.ficha.tecnocloud.es/registro.
model Plan {
  id           String        @id @default(cuid())
  key          String        @unique
  name         String
  description  String?
  active       Boolean       @default(true)
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  planFeatures PlanFeature[]

  @@map("plans")
  @@schema("master")
}

// Catálogo de features. Cada feature tiene un tipo (boolean/limit/quota).
// quotaPeriod solo aplica si type=quota (CHECK constraint en BD).
// Se siembra desde el catálogo §11.3 auditoría con ~30 entradas iniciales.
model Feature {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String?
  type        FeatureType
  quotaPeriod String?     @map("quota_period") // 'mes' o 'dia' si type=quota; NULL en otros
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("features")
  @@schema("master")
}

// Mapping: qué features tiene cada plan, con qué value.
// value es jsonb: bool true/false para boolean, integer para limit/quota,
// null para unlimited. ADR-003 §2.2 — sin FK a Feature porque feature_key
// puede no existir en eventos atrasados (auditoría sin acción).
model PlanFeature {
  id         String   @id @default(cuid())
  planId     String   @map("plan_id")
  plan       Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureKey String   @map("feature_key")
  value      Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([planId, featureKey])
  @@map("plan_features")
  @@schema("master")
}

// Features resueltas por tenant. ADR-003 §2.9 (enmendada en commit
// 3b7f7e1): manual_override > addon > plan para boolean; suma para
// limit y quota. Constraint UNIQUE (tenant_id, feature_key, source)
// garantiza una fila por origen.
//
// reason es obligatorio cuando source='manual_override' (CHECK con
// longitud mínima 10). El expires_at NULL significa sin expiración.
model TenantFeature {
  id         String        @id @default(cuid())
  tenantId   String        @map("tenant_id")
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureKey String        @map("feature_key")
  value      Json
  source     FeatureSource
  expiresAt  DateTime?     @map("expires_at")
  reason     String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@unique([tenantId, featureKey, source])
  @@index([tenantId, featureKey])
  @@map("tenant_features")
  @@schema("master")
}

// Subscription: una por tenant. ADR-003 §2.1 (modelo "una subscription
// con N items"). raw_event_id_last permite descartar eventos Stripe
// fuera de orden (ADR-003 §2.2).
model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @map("tenant_id")
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripeCustomerId     String             @map("stripe_customer_id")
  planKey              String             @map("plan_key")
  status               SubscriptionStatus
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  trialEnd             DateTime?          @map("trial_end")
  rawEventIdLast       String?            @map("raw_event_id_last")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  items                SubscriptionItem[]

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
  @@schema("master")
}

// Subscription items: el plan ocupa el primero, los addons los siguientes.
// ADR-003 §2.1 — "una subscription con N items".
// feature_key sin FK a Feature: ADR-003 §2.2 (mismo argumento que en
// PlanFeature — eventos atrasados con feature retirada).
model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String       @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  stripeItemId   String       @unique @map("stripe_item_id")
  featureKey     String       @map("feature_key")
  quantity       Int          @default(1)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("subscription_items")
  @@schema("master")
}

// ─── Producto (schema public — se moverá a tenant_<slug> en Fase 3) ────────────

enum Rol {
  OWNER // antes SUPERADMIN — admin del tenant. Reservado SUPERADMIN
  // para la plataforma (tabla super_admins en control plane).
  MANAGER
  EMPLEADO

  @@schema("public")
}

enum TipoFichaje {
  ENTRADA
  PAUSA
  VUELTA_PAUSA
  SALIDA

  @@schema("public")
}

enum MetodoFichaje {
  WEB
  MOVIL
  TABLET
  MANUAL

  @@schema("public")
}

enum EstadoAusencia {
  PENDIENTE
  APROBADA
  RECHAZADA
  CANCELADA

  @@schema("public")
}

enum EstadoTurno {
  BORRADOR
  PUBLICADO

  @@schema("public")
}

model Tienda {
  id           String    @id @default(cuid())
  nombre       String
  direccion    String
  ciudad       String
  codigoPostal String?
  telefono     String?
  email        String?
  latitud      Float?
  longitud     Float?
  radio        Int       @default(200)
  activa       Boolean   @default(true)
  color        String    @default("#6366f1")
  empleados    User[]
  fichajes     Fichaje[]
  turnos       Turno[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@schema("public")
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  password                 String?
  resetToken               String?                   @unique
  resetTokenExpiry         DateTime?
  nombre                   String
  apellidos                String
  dni                      String?                   @unique
  telefono                 String?
  foto                     String?
  fechaNacimiento          DateTime?
  rol                      Rol                       @default(EMPLEADO)
  tiendaId                 String?
  tienda                   Tienda?                   @relation(fields: [tiendaId], references: [id])
  activo                   Boolean                   @default(true)
  fichajes                 Fichaje[]
  turnos                   Turno[]
  ausencias                Ausencia[]                @relation("AusenciaEmpleado")
  ausenciasAprobadas       Ausencia[]                @relation("AusenciaAprobador")
  notificaciones           Notificacion[]
  tareas                   Tarea[]                   @relation("TareaAsignada")
  tareasCreadas            Tarea[]                   @relation("TareaCreada")
  comunicados              Comunicado[]
  articulos                Articulo[]
  documentos               Documento[]               @relation("DocumentoEmpleado")
  documentosSubidos        Documento[]               @relation("DocumentoSubido")
  onboardings              ProcesoOnboarding[]
  bolsaHoras               BolsaHoras[]
  bolsaHorasAprobadas      BolsaHoras[]              @relation("BolsaHorasAprobador")
  preferenciasNotificacion PreferenciasNotificacion?
  pushSubscripciones       PushSubscripcion[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@index([tiendaId])
  @@schema("public")
}

model Fichaje {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  tiendaId   String?
  tienda     Tienda?       @relation(fields: [tiendaId], references: [id])
  tipo       TipoFichaje
  timestamp  DateTime      @default(now())
  latitud    Float?
  longitud   Float?
  distancia  Float?
  metodo     MetodoFichaje @default(WEB)
  nota       String?
  editadoPor String?
  editadoEn  DateTime?
  ip         String?
  createdAt  DateTime      @default(now())

  @@index([userId])
  @@index([tiendaId])
  @@index([timestamp])
  @@schema("public")
}

model Turno {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  tiendaId   String
  tienda     Tienda      @relation(fields: [tiendaId], references: [id])
  fecha      DateTime
  horaInicio String
  horaFin    String
  nota       String?
  estado     EstadoTurno @default(BORRADOR)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
  @@index([tiendaId])
  @@index([fecha])
  @@schema("public")
}

model TipoAusencia {
  id                 String     @id @default(cuid())
  nombre             String
  color              String     @default("#6366f1")
  icono              String     @default("calendar")
  pagada             Boolean    @default(true)
  requiereAprobacion Boolean    @default(true)
  diasMaximos        Int?
  ausencias          Ausencia[]
  activo             Boolean    @default(true)
  createdAt          DateTime   @default(now())

  @@schema("public")
}

model Ausencia {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("AusenciaEmpleado", fields: [userId], references: [id])
  tipoAusenciaId  String
  tipoAusencia    TipoAusencia   @relation(fields: [tipoAusenciaId], references: [id])
  fechaInicio     DateTime
  fechaFin        DateTime
  dias            Int
  motivo          String?
  estado          EstadoAusencia @default(PENDIENTE)
  aprobadoPorId   String?
  aprobadoPor     User?          @relation("AusenciaAprobador", fields: [aprobadoPorId], references: [id])
  aprobadoEn      DateTime?
  comentarioAdmin String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([fechaInicio])
  @@schema("public")
}

model Notificacion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  titulo    String
  mensaje   String
  tipo      String   @default("info")
  leida     Boolean  @default(false)
  enlace    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@schema("public")
}

model ConfiguracionEmpresa {
  id                  String   @id @default(cuid())
  nombre              String   @default("Mi Empresa")
  logo                String?
  horasJornadaDiaria  Float    @default(8)
  horasSemanales      Float    @default(40)
  toleranciaFichaje   Int      @default(15)
  geofencingActivo    Boolean  @default(true)
  fichajeMovilActivo  Boolean  @default(true)
  fichajeTabletActivo Boolean  @default(true)
  // Notificaciones - eventos globales
  notifAusencias      Boolean  @default(true)
  notifTurnos         Boolean  @default(true)
  notifTareas         Boolean  @default(true)
  notifFichajes       Boolean  @default(false)
  notifComunicados    Boolean  @default(true)
  // Email
  emailActivo         Boolean  @default(false)
  emailHost           String?
  emailPort           Int?
  emailSecure         Boolean  @default(true)
  emailUser           String?
  emailPassword       String?
  emailFrom           String?
  // Push
  pushActivo          Boolean  @default(false)
  pushVapidPublicKey  String?
  pushVapidPrivateKey String?
  // Branding
  favicon             String? // base64 data URL
  colorPrimario       String   @default("#6366f1")
  colorSidebar        String   @default("#1e1b4b")
  appNombre           String   @default("TelecomFichaje")
  updatedAt           DateTime @updatedAt

  @@schema("public")
}

model PreferenciasNotificacion {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // In-app
  inAppAusencias   Boolean  @default(true)
  inAppTurnos      Boolean  @default(true)
  inAppTareas      Boolean  @default(true)
  inAppFichajes    Boolean  @default(false)
  inAppComunicados Boolean  @default(true)
  // Email
  emailAusencias   Boolean  @default(true)
  emailTurnos      Boolean  @default(true)
  emailTareas      Boolean  @default(false)
  emailFichajes    Boolean  @default(false)
  emailComunicados Boolean  @default(false)
  // Push
  pushAusencias    Boolean  @default(true)
  pushTurnos       Boolean  @default(true)
  pushTareas       Boolean  @default(true)
  pushFichajes     Boolean  @default(false)
  pushComunicados  Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  @@schema("public")
}

model PushSubscripcion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@schema("public")
}

model Tarea {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  prioridad   String    @default("MEDIA")
  completada  Boolean   @default(false)
  fechaLimite DateTime?
  asignadoAId String?
  asignadoA   User?     @relation("TareaAsignada", fields: [asignadoAId], references: [id])
  creadoPorId String
  creadoPor   User      @relation("TareaCreada", fields: [creadoPorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([asignadoAId])
  @@index([creadoPorId])
  @@schema("public")
}

model Comunicado {
  id          String    @id @default(cuid())
  titulo      String
  contenido   String
  publicado   Boolean   @default(false)
  publicadoEn DateTime?
  autorId     String
  autor       User      @relation(fields: [autorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([autorId])
  @@schema("public")
}

model Articulo {
  id        String   @id @default(cuid())
  titulo    String
  contenido String
  categoria String   @default("general")
  publicado Boolean  @default(false)
  vistas    Int      @default(0)
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([autorId])
  @@schema("public")
}

model Documento {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  url         String?
  tipo        String   @default("otro")
  userId      String?
  user        User?    @relation("DocumentoEmpleado", fields: [userId], references: [id])
  subidoPorId String
  subidoPor   User     @relation("DocumentoSubido", fields: [subidoPorId], references: [id])
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([subidoPorId])
  @@schema("public")
}

model Festivo {
  id        String   @id @default(cuid())
  nombre    String
  fecha     DateTime
  ambito    String   @default("nacional")
  createdAt DateTime @default(now())

  @@schema("public")
}

model ProcesoOnboarding {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  tipo        String            @default("ONBOARDING")
  estado      String            @default("PENDIENTE")
  fechaInicio DateTime
  fechaFin    DateTime?
  notas       String?
  tareas      TareaOnboarding[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@schema("public")
}

model TareaOnboarding {
  id          String            @id @default(cuid())
  procesoId   String
  proceso     ProcesoOnboarding @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  titulo      String
  descripcion String?
  completada  Boolean           @default(false)
  orden       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([procesoId])
  @@schema("public")
}

model PlantillaTareaOnboarding {
  id          String   @id @default(cuid())
  tipo        String // "ONBOARDING" | "OFFBOARDING"
  titulo      String
  descripcion String?
  orden       Int      @default(0)
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model BolsaHoras {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  tipo          String // "ACUMULACION" | "CONSUMO"
  horas         Float
  concepto      String
  fecha         DateTime
  aprobadoPorId String?
  aprobadoPor   User?    @relation("BolsaHorasAprobador", fields: [aprobadoPorId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@schema("public")
}
