generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["master"]
}

// ─── Control plane (schema master) ─────────────────────────────────────────────
//
// Enums introducidos en Fase 2 (commit 1). Los modelos del control plane se
// añaden en commits siguientes.

enum TenantStatus {
  pending
  provisioning
  active
  suspended
  deleted

  @@schema("master")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  unpaid
  canceled
  paused
  incomplete
  incomplete_expired

  @@schema("master")
}

enum FeatureSource {
  plan
  addon
  manual_override

  @@schema("master")
}

enum FeatureType {
  boolean
  limit
  quota

  @@schema("master")
}

enum PlatformRol {
  SUPER_ADMIN
  SUPPORT

  @@schema("master")
}

// Tenant: núcleo del control plane.
//
// El CHECK del slug `^[a-z][a-z0-9_]{2,30}$` se aplica con un CHECK constraint
// SQL añadido en la migración (Prisma no soporta CHECK declarativo todavía).
// El trigger `tenants_slug_not_reserved` rechaza inserts cuyo slug colisione
// con master.reserved_slugs (también en SQL).
//
// La columna stripe_customer_id es nullable hasta que el primer checkout
// asigna el Customer Stripe. Para el cliente actual del cutover (Fase 8) se
// usa el sentinel "cus_manual_<id>" que no colisiona con prefijos reales.
model Tenant {
  id               String             @id @default(cuid())
  slug             String             @unique
  name             String
  email            String
  status           TenantStatus       @default(pending)
  stripeCustomerId String?            @unique @map("stripe_customer_id")
  // Fase 6 §4.1: dominio personalizado.
  // Resuelve a este tenant solo si verified=true Y la feature
  // dominio_personalizado está activa (chequeada en proxy.ts).
  customDomain         String?            @unique @map("custom_domain")
  customDomainVerified Boolean            @default(false) @map("custom_domain_verified")
  customDomainToken    String?            @map("custom_domain_token")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at")
  tenantFeatures   TenantFeature[]
  subscriptions    Subscription[]
  quotaUsage       TenantQuotaUsage[]

  @@index([status])
  @@map("tenants")
  @@schema("master")
}

// Slugs reservados de la plataforma. Trigger en master.tenants rechaza
// inserts cuyo slug exista aquí. Lista inicial sembrada en seeds.
model ReservedSlug {
  slug      String   @id
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reserved_slugs")
  @@schema("master")
}

// Plan: starter / pro / enterprise. Sin precios — los precios viven en
// Stripe (vars STRIPE_PRICE_* de ADR-005 §2.3.b). Aquí solo metadatos
// para la UI de selección de plan en app.ficha.tecnocloud.es/registro.
model Plan {
  id           String        @id @default(cuid())
  key          String        @unique
  name         String
  description  String?
  active       Boolean       @default(true)
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  planFeatures PlanFeature[]

  @@map("plans")
  @@schema("master")
}

// Catálogo de features. Cada feature tiene un tipo (boolean/limit/quota).
// quotaPeriod solo aplica si type=quota (CHECK constraint en BD).
// Se siembra desde el catálogo §11.3 auditoría con ~30 entradas iniciales.
model Feature {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String?
  type        FeatureType
  quotaPeriod String?     @map("quota_period") // 'mes' o 'dia' si type=quota; NULL en otros
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")

  @@map("features")
  @@schema("master")
}

// Mapping: qué features tiene cada plan, con qué value.
// value es jsonb: bool true/false para boolean, integer para limit/quota,
// null para unlimited. ADR-003 §2.2 — sin FK a Feature porque feature_key
// puede no existir en eventos atrasados (auditoría sin acción).
model PlanFeature {
  id         String   @id @default(cuid())
  planId     String   @map("plan_id")
  plan       Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureKey String   @map("feature_key")
  value      Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([planId, featureKey])
  @@map("plan_features")
  @@schema("master")
}

// Features resueltas por tenant. ADR-003 §2.9 (enmendada en commit
// 3b7f7e1): manual_override > addon > plan para boolean; suma para
// limit y quota. Constraint UNIQUE (tenant_id, feature_key, source)
// garantiza una fila por origen.
//
// reason es obligatorio cuando source='manual_override' (CHECK con
// longitud mínima 10). El expires_at NULL significa sin expiración.
model TenantFeature {
  id         String        @id @default(cuid())
  tenantId   String        @map("tenant_id")
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureKey String        @map("feature_key")
  value      Json
  source     FeatureSource
  expiresAt  DateTime?     @map("expires_at")
  reason     String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @default(now()) @updatedAt @map("updated_at")

  @@unique([tenantId, featureKey, source])
  @@index([tenantId, featureKey])
  @@map("tenant_features")
  @@schema("master")
}

// Subscription: una por tenant. ADR-003 §2.1 (modelo "una subscription
// con N items"). raw_event_id_last permite descartar eventos Stripe
// fuera de orden (ADR-003 §2.2).
model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @map("tenant_id")
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripeCustomerId     String             @map("stripe_customer_id")
  planKey              String             @map("plan_key")
  status               SubscriptionStatus
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  trialEnd             DateTime?          @map("trial_end")
  rawEventIdLast       String?            @map("raw_event_id_last")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at")
  items                SubscriptionItem[]

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
  @@schema("master")
}

// Subscription items: el plan ocupa el primero, los addons los siguientes.
// ADR-003 §2.1 — "una subscription con N items".
// feature_key sin FK a Feature: ADR-003 §2.2 (mismo argumento que en
// PlanFeature — eventos atrasados con feature retirada).
model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String       @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  stripeItemId   String       @unique @map("stripe_item_id")
  featureKey     String       @map("feature_key")
  quantity       Int          @default(1)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("subscription_items")
  @@schema("master")
}

// Contadores de quota con periodo de reset. ADR-004 §2.3.
//
// Una fila por (tenant, feature, periodo). El periodo coincide con
// current_period_start/end de la subscription cuando aplica.
//
// max = NULL significa unlimited. Filas viejas no se borran (auditables);
// un job de Fase 9 archiva las > N meses.
//
// Acceso desde la app: solo via prismaQuotaWriter (quota_writer_role,
// ADR-004 §2.2). El UPDATE atómico de consumeQuota usa esta tabla.
model TenantQuotaUsage {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureKey  String   @map("feature_key")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  consumed    BigInt   @default(0)
  max         BigInt?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([tenantId, featureKey, periodStart])
  @@index([tenantId, featureKey, periodEnd])
  @@map("tenant_quota_usage")
  @@schema("master")
}

// Cuentas de plataforma. Independientes de los tenants — viven aquí
// para que el panel super-admin (admin.ficha.tecnocloud.es) tenga
// auth propia sin reutilizar el flow de NextAuth de los tenants
// (ADR-002 §2.5; ADR-007 cerrará el panel completo).
//
// password es hash bcrypt (mismo método que User.password). El
// comando npm run super-admin:create lo gestiona.
model SuperAdmin {
  id        String      @id @default(cuid())
  email     String      @unique
  password  String
  name      String
  role      PlatformRol @default(SUPER_ADMIN)
  active    Boolean     @default(true)
  lastLogin DateTime?   @map("last_login")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at")
  auditLogs AuditLog[]

  @@map("super_admins")
  @@schema("master")
}

// Audit log de operaciones del panel super-admin. ADR-007 §2.4.
// Se conserva indefinidamente. Cron de archivado entries > 7 años Fase 9.
model AuditLog {
  id           String     @id @default(cuid())
  superAdminId String     @map("super_admin_id")
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id])
  action       String
  targetKind   String     @map("target_kind")
  targetId     String     @map("target_id")
  severity     String     @default("info") // 'info' | 'warning' | 'critical'
  summary      Json       @default("{}")
  dumpPath     String?    @map("dump_path")
  ipAddress    String?    @map("ip_address")
  userAgent    String?    @map("user_agent")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([superAdminId])
  @@index([targetKind, targetId])
  @@index([severity, createdAt])
  @@index([createdAt])
  @@map("audit_log")
  @@schema("master")
}

// Idempotencia de webhooks Stripe. ADR-003 §2.2 + §2.4.
// PK = event_id (de Stripe). El INSERT ON CONFLICT DO NOTHING
// RETURNING blinda contra retries del propio Stripe.
//
// processed_at = NULL distingue "ignorado intencional" (eventos
// fuera de la lista blanca §2.3.b) de "procesado": el handler
// marca processed_at al terminar; los ignorados se quedan a NULL
// para auditoría.
model StripeEvent {
  eventId         String    @id @map("event_id")
  type            String
  apiVersion      String    @map("api_version")
  createdAt       DateTime  @map("created_at")
  receivedAt      DateTime  @default(now()) @map("received_at")
  processedAt     DateTime? @map("processed_at")
  processingError String?   @map("processing_error")
  payload         Json

  @@index([type])
  @@index([receivedAt])
  @@map("stripe_events")
  @@schema("master")
}
